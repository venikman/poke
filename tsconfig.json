{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node", "@rstest/core/globals"]
  },
  "include": [
    "app",
    "server",
    "tests",
    "rsbuild.config.ts",
    "rstest.config.ts",
    "react-router.config.ts",
    "playwright.config.ts"
  ]
}

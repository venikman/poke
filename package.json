    "@mui/material": "^7.3.8",
    "hono": "^4.12.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@playwright/test": "^1.58.2",
    "@react-router/dev": "^7.13.1",
    "@rsbuild/core": "^1.7.3",
    "@rsbuild/plugin-react": "^1.4.5",
    "@rstest/browser": "^0.9.0",
    "@rstest/browser-react": "^0.9.0",
    "@rstest/core": "^0.9.0",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "rsbuild-plugin-react-router": "^0.1.1",

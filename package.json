{
  "name": "full-stack-rs-hello-world",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.13.0"
  },
  "scripts": {
    "dev": "dotnet run --project aspire/Poke.AppHost",
    "build": "rsbuild build && tsc --project tsconfig.server.json",
